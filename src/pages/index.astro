---
import MainLayout from '../layouts/MainLayout.astro';

const skillsOS = ["Kali Linux", "Debian", "Ubuntu", "Fedora", "Arch", "Windows", "macOS"];
const skillsCyber = ["Nmap", "Wireshark", "Burp Suite", "John The Ripper", "Hydra", "Sherlock", "Maltego", "Tcpdump", "Metasploit", "Hping3", "Scapy", "Aircrack-ng", "Cisco Packet Tracer"];
const skillsDev = ["HTML / CSS", "C / C++", "Python", "Bash"];
---

<MainLayout>
  <header class="navbar">
    <nav aria-label="Navigation principale">
      <div class="logo">Malo.dev <span class="cyber-badge">PenTest</span></div>
      <ul class="nav-links">
        <li><a href="#accueil">Accueil</a></li>
        <li><a href="#profil">Profil</a></li>
        <li><a href="#competences">Compétences</a></li>
        <li><a href="#projets">Projets</a></li>
        <li><button id="theme-toggle" aria-label="Changer le thème">
          <svg class="icon theme-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        </button></li>
      </ul>
    </nav>
  </header>

  <main>
    <section id="accueil" class="hero relative overflow-hidden">
      <div class="video-wrapper">
        <video autoplay loop muted playsinline class="bg-video">
          <source src="/videos/cyber-bg.mp4" type="video/mp4" />
        </video>
        <div class="video-overlay"></div>
      </div>

      <div class="hero-content relative z-20">
        <h1>Malo <br/> <span class="highlight typewriter" id="typewriter"></span></h1>
        <p class="hero-subtitle">Étudiant en BTS CIEL - Spécialisation Cybersécurité & Réseaux.</p>
        
        <div class="hero-actions">
          <a href="#projets" class="cta-button">Découvrir mes projets</a>
          <a href="#profil" class="secondary-button">Mon Profil</a>
        </div>

        <div class="social-links">
          <a href="https://github.com/AzouC" target="_blank" rel="noopener noreferrer" class="social-badge">GitHub</a>
          <a href="https://www.root-me.org/AzouC" target="_blank" rel="noopener noreferrer" class="social-badge root-me">Root-Me</a>
          <a href="https://discordapp.com/users/a_zouzou" target="_blank" rel="noopener noreferrer" class="social-badge discord">Discord</a>
        </div>
      </div>
    </section>

    <section id="profil" class="section reveal">
      <h2>À propos de <span class="highlight">moi</span></h2>
      <p class="subtitle">18 ans • Français • Bassin Rennais</p>
      <div class="bio-card">
        <p>Étudiant en 1ère année de <strong>BTS CIEL</strong>, je suis passionné par le Penetration Testing. Curieux et assidu, je cherche une <strong>alternance</strong> pour mettre mes compétences à l'épreuve.</p>
      </div>
    </section>
    
    </main>

  <footer class="footer">
    <p>© 2026 Malo - Fait avec rigueur.</p>
  </footer>

  <script is:inline>
    const textElement = document.getElementById('typewriter');
    const phrases = ["Futur Expert Cybersécurité", "PenTtester Junior", "Passionné Linux & Réseaux"];
    let phraseIndex = 0;
    let charIndex = 0;
    let isDeleting = false;

    function type() {
      const currentPhrase = phrases[phraseIndex];
      
      if (isDeleting) {
        textElement.textContent = currentPhrase.substring(0, charIndex - 1);
        charIndex--;
      } else {
        textElement.textContent = currentPhrase.substring(0, charIndex + 1);
        charIndex++;
      }

      let typeSpeed = isDeleting ? 50 : 100;

      if (!isDeleting && charIndex === currentPhrase.length) {
        isDeleting = true;
        typeSpeed = 2000; // Pause à la fin du mot
      } else if (isDeleting && charIndex === 0) {
        isDeleting = false;
        phraseIndex = (phraseIndex + 1) % phrases.length;
        typeSpeed = 500;
      }

      setTimeout(type, typeSpeed);
    }

    document.addEventListener('DOMContentLoaded', type);
  </script>

</MainLayout>

<style>
  /* --- STYLES ESSENTIELS --- */
  .navbar { position: fixed; top: 0; width: 100%; padding: 1rem 5%; background-color: var(--nav-bg); backdrop-filter: blur(10px); z-index: 100; }
  nav { display: flex; justify-content: space-between; align-items: center; max-width: 1200px; margin: 0 auto; }
  .nav-links { list-style: none; display: flex; gap: 1.5rem; }
  .nav-links a { color: var(--text-color); text-decoration: none; }
  
  main { width: 100%; }
  .section { max-width: 1000px; margin: 0 auto; padding: 5rem 5%; }

  /* HERO & VIDEO FULLSCREEN */
  .hero { 
    height: 100vh; 
    display: flex; 
    align-items: center; 
    justify-content: center; 
    text-align: center;
    position: relative;
  }
  
  .video-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }
  .bg-video { width: 100%; height: 100%; object-fit: cover; }
  .video-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.6); /* Filtre pour voir le texte */
    z-index: 2;
  }

  .hero-content {
    z-index: 10; /* Assure que le texte est AU-DESSUS de la vidéo */
    color: white;
  }

  h1 { font-size: 4rem; margin-bottom: 1rem; color: white; }
  .highlight { color: #2563eb; }
  
  /* Effet curseur pour la machine à écrire */
  .typewriter::after {
    content: "|";
    animation: blink 0.7s infinite;
  }
  @keyframes blink { 50% { opacity: 0; } }

  .hero-subtitle { font-size: 1.5rem; margin-bottom: 2rem; color: rgba(255,255,255,0.9); }
  .hero-actions { display: flex; gap: 1rem; justify-content: center; }
  
  .cta-button { background: #2563eb; color: white; padding: 0.8rem 1.5rem; border-radius: 8px; text-decoration: none; }
  .secondary-button { border: 2px solid white; color: white; padding: 0.8rem 1.5rem; border-radius: 8px; text-decoration: none; }

  .social-links { display: flex; gap: 1rem; justify-content: center; margin-top: 2rem; }
  .social-badge { background: rgba(255,255,255,0.1); padding: 0.5rem 1rem; border-radius: 5px; color: white; text-decoration: none; }
  
  .highlight { color: #60a5fa; }
</style>