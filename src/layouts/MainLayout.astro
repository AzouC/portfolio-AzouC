---
import '../styles/global.css';
import '../styles/print.css';

const { title = "Portfolio | Malo - Cybersécurité" } = Astro.props;
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <!--
      ANTI-FOUC : Ce script DOIT rester inline pour s'exécuter avant le premier
      rendu et éviter le flash blanc→noir en mode sombre.

      ⚠️  IMPORTANT CSP : Le hash SHA-256 de CE script exact est déclaré dans _headers.
          Si vous modifiez la moindre virgule ici, vous DEVEZ recalculer le hash avec :
          printf '%s' '<contenu>' | openssl dgst -sha256 -binary | base64

      Hash actuel : sha256-ABXcc86eRLjpNmOa/Gzdk3rjEsB7z/Rj+bnOFEEIXOA=
    -->
    <script is:inline>(function(){var t=localStorage.getItem('theme');if(t==='dark'||(!t&&window.matchMedia('(prefers-color-scheme: dark)').matches)){document.documentElement.classList.add('dark');}})();</script>
  </head>
  <body class="bg-white dark:bg-slate-950 text-slate-900 dark:text-slate-100">
    <div class="relative flex min-h-screen flex-col">
      <main class="flex-auto">
        <slot />
      </main>
    </div>
  </body>
</html>
